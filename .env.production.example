# Copie este arquivo para .env.production no servidor.
# Nunca use admin/admin em producao real.

# Dominio sem http/https, usado pelo Caddy para gerar HTTPS automatico.
PUBLIC_HOST=seudominio.com

# URL publica completa usada pelo backend.
PUBLIC_URL=https://seudominio.com

# Porta local para debug direto no servidor. O publico deve entrar por 80/443.
APP_PORT=5000

POSTGRES_DB=barbergo
POSTGRES_USER=barbergo
POSTGRES_PASSWORD=troque-esta-senha-do-postgres

JWT_SECRET=troque-por-um-segredo-grande-com-mais-de-24-caracteres
JWT_TTL_DAYS=7
SAAS_TRIAL_DAYS=14

SEED_OWNER_NAME=Administrador
SEED_OWNER_EMAIL=admin
SEED_OWNER_PASSWORD=admin
SEED_BARBERSHOP_NAME=Barbearia Principal
SEED_BARBERSHOP_SLUG=barbearia-principal
SEED_BARBERSHOP_PHONE=
SEED_WHATSAPP_NUMBER=
SEED_BARBERSHOP_ADDRESS=

CHATBOT_ENABLED=true
CHATBOT_INTERNAL_SECRET=troque-por-um-segredo-grande-e-diferente

DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=15000
DATABASE_IDLE_TIMEOUT_MS=30000
