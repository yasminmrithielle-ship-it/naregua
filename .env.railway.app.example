# Railway - Aplicacao principal (backend + frontend + chatbot integrado)
# Cole estas variaveis no servico principal do Railway.
# O PORT normalmente e fornecido automaticamente pelo Railway.
# IMPORTANTE:
# - Crie um servico PostgreSQL no mesmo projeto Railway.
# - Se o servico do banco se chamar "Postgres", use DATABASE_URL=${{Postgres.DATABASE_URL}}.
# - API_URL pode usar o dominio publico gerado pelo Railway.
# - Depois de alterar as variaveis, faca um novo deploy no Railway.

DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_SSL=false
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=15000
DATABASE_IDLE_TIMEOUT_MS=30000
API_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}
JWT_SECRET=troque-por-um-segredo-grande-com-mais-de-24-caracteres
JWT_TTL_DAYS=7
CORS_ORIGINS=https://${{RAILWAY_PUBLIC_DOMAIN}},capacitor://localhost
SAAS_TRIAL_DAYS=14

# Frontend e backend ficam no mesmo dominio.
VITE_API_URL=
VITE_CHATBOT_URL=

# Chatbot integrado no mesmo servico.
CHATBOT_PUBLIC_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}
CHATBOT_ENABLED=true
CHATBOT_WEBHOOK_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}/webhook
CHATBOT_INTERNAL_SECRET=troque-por-um-segredo-grande-e-diferente
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Recomendado para Chromium/WhatsApp Web no Railway.
RAILWAY_SHM_SIZE_BYTES=524288000

# Seed opcional da primeira conta
SEED_OWNER_NAME=Administrador
SEED_OWNER_EMAIL=admin
SEED_OWNER_PASSWORD=admin
SEED_BARBERSHOP_NAME=Barbearia Principal
SEED_BARBERSHOP_SLUG=barbearia-principal
SEED_BARBERSHOP_PHONE=
SEED_WHATSAPP_NUMBER=
SEED_BARBERSHOP_ADDRESS=
