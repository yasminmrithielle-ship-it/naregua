# Railway - Aplicacao principal (backend + frontend)
# Cole estas variaveis no servico principal do Railway.
# O PORT normalmente e fornecido automaticamente pelo Railway.
# IMPORTANTE:
# - Substitua a DATABASE_URL pela string REAL copiada do Supabase.
# - Nao use placeholders como REGION, PROJECT_REF ou SENHA_REAL em producao.
# - Depois de alterar as variaveis, faca um novo deploy no Railway.

ADMIN_USER=admin
ADMIN_PASS=troque-esta-senha

# Exemplo de formato valido:
# DATABASE_URL=postgresql://postgres.xxxxxxxx:SENHA_REAL@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
# Cole abaixo a URI completa gerada pelo painel do Supabase.
DATABASE_URL=postgresql://postgres.PROJECT_REF:SENHA_REAL@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
DATABASE_SSL=true
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=15000
DATABASE_IDLE_TIMEOUT_MS=30000

BARBEARIA_ID=default
BARBEARIA_NOME=BARBEARIA DO NEGAO

API_URL=https://SEU-APP.up.railway.app

# Frontend build vars
# Deixe VITE_API_URL vazio quando frontend e backend estiverem no mesmo servico Railway.
VITE_API_URL=
VITE_CHATBOT_URL=https://SEU-CHATBOT.up.railway.app/qr

# Chatbot integrado no backend
# Use true se quiser rodar frontend + backend + chatbot no mesmo servico Railway.
CHATBOT_ENABLED=false
CHATBOT_WEBHOOK_URL=
CHATBOT_INTERNAL_SECRET=troque-por-um-segredo-grande-e-igual-no-chatbot
