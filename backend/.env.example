PORT=5000
# Local:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/barbearia
# Supabase local/dev:
DATABASE_URL=postgresql://postgres:[SUA-SENHA]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
# Supabase no Railway:
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[SUA-SENHA]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_SSL=true
# Seed local padrao
SEED_OWNER_NAME=Administrador
SEED_OWNER_EMAIL=admin
SEED_OWNER_PASSWORD=admin
SEED_BARBERSHOP_NAME=Barbearia Principal
SEED_BARBERSHOP_SLUG=barbearia-principal
API_URL=http://localhost:5000
BARBEARIA_ID=default
BARBEARIA_NOME=Sua Barbearia
CHATBOT_WEBHOOK_URL=http://localhost:5000/webhook
CHATBOT_ENABLED=false
